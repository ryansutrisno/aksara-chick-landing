---
/**
 * Meta Pixel (Facebook Pixel) Integration
 *
 * Usage:
 *   1. Set PUBLIC_META_PIXEL_ID in your environment (.env or Vercel dashboard)
 *   2. This component auto-injects into <head> via BaseLayout
 *
 * Tracking events:
 *   - Automatic: PageView (fires on every page load)
 *   - Manual: Use window.fbq('track', 'EventName', { ...params }) in client scripts
 *
 * Common events: Lead, Purchase, AddToCart, Contact, CompleteRegistration
 */

const PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID || '';
const HAS_PIXEL = PIXEL_ID.length > 0;

const fbBase = 'https://connect.facebook.net/en_US/fbevents.js';
const trBase = 'https://www.facebook.com/tr?id=';
const noscriptUrl = trBase + PIXEL_ID + '&ev=PageView&noscript=1';

const pixelScript =
  '!function(){var f,b,e,v,n,t,s,fbq;f=b=fbq=function(){fbq.callMethod?' +
  'fbq.callMethod.apply(fbq,arguments):fbq.queue.push(arguments)};if(!f._fbq)f._fbq=f;' +
  "n=f.createElement('script');n.async=!0;" +
  "n.src='" +
  fbBase +
  "';" +
  "s=f.getElementsByTagName('script')[0];s.parentNode.insertBefore(n,s);" +
  "fbq.init('" +
  PIXEL_ID +
  "');" +
  "fbq.push('pageView');" +
  "window.fbq=fbq;fbq.queue=fbq.queue||[];fbq.loaded=!0;fbq.version='2.0';" +
  "fbq.agent='stago';" +
  "}();";
---

{HAS_PIXEL && (
  <>
    <!-- Meta Pixel Base Code -->
    <script set:html={pixelScript} />
    <!-- End Meta Pixel Base Code -->

    <!-- Meta Pixel Noscript -->
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src={noscriptUrl}
        alt="facebook-pixel"
      />
    </noscript>
    <!-- End Meta Pixel Noscript -->

    <!-- WA Link Click Tracker -->
    <script>
      {`
      (function() {
        function detectSource(el) {
          var walk = el;
          while (walk && walk !== document.body) {
            var id = (walk.id || '').toLowerCase();
            var cls = (walk.className || '').toString().toLowerCase();
            if (/navbar|nav-/.test(id) || /nav-/.test(cls)) return 'Navbar';
            if (/sticky/.test(id) || /sticky/.test(cls)) return 'Sticky WA';
            if (/cta/.test(id) || /cta/.test(cls)) return 'CTA';
            if (/hero/.test(id) || /hero/.test(cls)) return 'Hero';
            if (/produk|card/.test(id) || /produk|card/.test(cls)) return 'Products';
            walk = walk.parentElement;
          }
          return 'Other';
        }
        document.addEventListener('click', function(e) {
          if (typeof window.fbq !== 'function') return;
          var a = e.target.closest('a[href*="wa.me"]');
          if (!a) return;
          var source = detectSource(a);
          window.fbq('track', 'Contact', {
            content_name: 'WhatsApp Click - ' + source,
            source: source
          });
        }, true);
      })();
      `}
    </script>
  </>
)}
